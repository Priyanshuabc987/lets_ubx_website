rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Securely checks if the user has an 'admin' role in their 'roles' array
    function isAdmin() {
      return isSignedIn() && 'admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }
    // (Simplified) Only admins are allowed to perform writes for FIX registrations.
    // Public collection is readable by anyone; private collection is accessible only to admins.

    // --- SECURITY RULES ---
    // Rule for the 'users' collection
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId || isAdmin();
      allow create, delete: if isAdmin();
    }

    // Rule for the 'events' collection
    match /events/{eventsId} {
      allow read: if true; // Allow public read access
      allow write: if isAdmin(); // Only admins can write
    }

    // Rule for the 'gallery' collection
    match /gallery/{galleryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Rule for the 'hero' collection
    match /hero/{heroId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
     // Rule for the 'social post' collection
    match /social_posts/{social_postsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Fix registrations split into public and private collections
    // We keep all sensitive information in `fix_registrations_private` and disallow any client
    // read/write. All server interactions must use the Admin SDK.
    match /fix_registrations_public/{docId} {
      // Public collection usage is deprecated for privacy; disallow client access.
      allow read, write: if false;
    }

    // Private: only accessible by Admin SDK. Deny all client reads/writes.
    match /fix_registrations_private/{docId} {
      allow read, write: if false;
    }
    

  }
}